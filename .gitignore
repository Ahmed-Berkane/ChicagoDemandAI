# =============================================================================
# DEPLOYMENT TRACK (keep in git):
#   src/                  Python package
#   src/data/unified_df.parquet   source modeling table (from data_loader notebook)
#   requirements.txt      dependencies
#   app_streamlit/        Streamlit app (when present)
#   models/               preprocessor + trained model for inference
#   README.md
# =============================================================================

# --- Local development (not needed to run the app) ---
#notebooks/
docs/
Documents/
scripts/

# --- Data: runner.py regenerates splits from unified_df ---
DataSourceCSV/
/data/

# Ignore everything under src/data/ except the deployed parquet
src/data/*
!src/data/
!src/data/unified_df.parquet

# --- Python / env ---
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
.env
.env.*

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- IDE / OS ---
.idea/
.vscode/
.cursor/
.DS_Store
Thumbs.db
*.swp

# --- Build / cache ---
*.parquet
!src/data/unified_df.parquet
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Logs & temp ---
*.log
*.tmp
~$*
