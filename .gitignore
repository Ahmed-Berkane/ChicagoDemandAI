# =============================================================================
# DEPLOYMENT TRACK (keep in git):
#   src/                  Python package
#   requirements.txt      dependencies
#   app_streamlit/        Streamlit app (when present)
#   models/               preprocessor + trained model for inference
#   data/processed/unified_daily_demand.parquet   final modeling table
#   README.md
# =============================================================================

# --- Local development (not needed to run the app) ---
#notebooks/
docs/
Documents/
scripts/

# --- Data: ignore raw/cache locally; only ship the final parquet ---
DataSourceCSV/
data/*
!data/processed/
data/processed/*
!data/processed/unified_daily_demand.parquet

# --- Python / env ---
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
.env
.env.*

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- IDE / OS ---
.idea/
.vscode/
.cursor/
.DS_Store
Thumbs.db
*.swp

# --- Build / cache ---
*.parquet
!data/processed/unified_daily_demand.parquet
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Logs & temp ---
*.log
*.tmp
~$*
